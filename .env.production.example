# ============================================================
# Jarreva Creative — Production Environment Variables
# ============================================================
# Copy these values to your Koyeb dashboard:
#   Service > Settings > Environment Variables
#
# DO NOT commit real passwords/keys to git!
# ============================================================

# === Application ===
APP_NAME="Jarreva Creative"
APP_ENV=production
APP_KEY=                          # Run `php artisan key:generate --show` locally, paste result
APP_DEBUG=false
APP_URL=                          # Koyeb: https://your-app.koyeb.app or custom domain

# === Database (Supabase PostgreSQL) ===
DB_CONNECTION=pgsql
DB_HOST=                          # Supabase: db.<project-ref>.supabase.co
DB_PORT=5432                      # Supabase: 5432 (direct) or 6543 (pooler)
DB_DATABASE=postgres              # Supabase: default database name
DB_USERNAME=postgres              # Supabase: default user
DB_PASSWORD=                      # Supabase: project password (set in dashboard ONLY)
DB_SSLMODE=require                # Supabase: requires SSL

# === Session & Cache ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

# === Logging ===
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# === Mail (Gmail SMTP via App Password) ===
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=jarrevacreative@gmail.com
MAIL_PASSWORD=                    # Set in Koyeb dashboard ONLY — never commit!
MAIL_FROM_ADDRESS="jarrevacreative@gmail.com"
MAIL_FROM_NAME="Jarreva Creative"

# === CDN (Cloudflare Pages — static assets) ===
ASSET_CDN_ENABLED=true
ASSET_CDN_URL=https://jarreva-frontend-assets.pages.dev

# === Supabase Storage (S3-compatible, for book covers & admin photos) ===
SUPABASE_STORAGE_URL=             # https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_STORAGE_KEY=             # Supabase: service_role key
SUPABASE_STORAGE_SECRET=          # Supabase: service_role secret
SUPABASE_STORAGE_BUCKET=media     # Bucket name (create in Supabase dashboard)
SUPABASE_STORAGE_REGION=auto      # Usually "auto" for Supabase
SUPABASE_STORAGE_PUBLIC_URL=      # https://<project-ref>.supabase.co/storage/v1/object/public/media

# === Security ===
BCRYPT_ROUNDS=12

# === Server ===
PORT=8000
