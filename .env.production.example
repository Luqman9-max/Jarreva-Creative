# ============================================================
# Jarreva Creative — Production Environment Variables
# ============================================================
# Copy this file and set values in your Railway dashboard:
#   Settings > Variables
#
# DO NOT commit real values to git!
# ============================================================

# === Application ===
APP_NAME="Jarreva Creative"
APP_ENV=production
APP_KEY=                          # Railway: run `php artisan key:generate --show` locally, paste result
APP_DEBUG=false
APP_URL=                          # Railway: your-app.up.railway.app or custom domain

# === Database (Railway MySQL addon auto-fills these) ===
DB_CONNECTION=mysql
DB_HOST=                          # Railway: auto-provided via MYSQLHOST
DB_PORT=3306                      # Railway: auto-provided via MYSQLPORT
DB_DATABASE=                      # Railway: auto-provided via MYSQLDATABASE
DB_USERNAME=                      # Railway: auto-provided via MYSQLUSER
DB_PASSWORD=                      # Railway: auto-provided via MYSQLPASSWORD

# === Session & Cache ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

# === Logging ===
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# === Mail ===
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=jarrevacreative@gmail.com
MAIL_PASSWORD=                    # Set in Railway dashboard ONLY — never commit!
MAIL_FROM_ADDRESS="jarrevacreative@gmail.com"
MAIL_FROM_NAME="Jarreva Creative"

# === CDN (activate after Cloudflare Pages setup) ===
ASSET_CDN_ENABLED=false
ASSET_CDN_URL=                    # e.g., https://jarreva-assets.pages.dev

# === Security ===
BCRYPT_ROUNDS=12
