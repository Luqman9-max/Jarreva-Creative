/storage/pail
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*

# IDE and OS files
.DS_Store
.idea
.vscode
.fleet
.nova
.zed
.phpactor.json
Thumbs.db

# Git
.git
.gitattributes

# Testing
.phpunit.result.cache
.phpunit.cache

# Documentation (not needed in image)
deployment_guide.md
README.md

